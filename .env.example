# ═══════════════════════════════════════════════════════════
# Copa GD 2026 — Variáveis de ambiente
# Copie para .env na raiz do projeto (ou configure no painel do host)
# ═══════════════════════════════════════════════════════════

# ── Obrigatórias (produção / website builder) ──────────────
NODE_ENV=production
PORT=3000
# ⚠️ NÃO use "host" — coloque o hostname REAL do seu PostgreSQL:
# Ex Hostinger: postgresql://u123456789_copa:SenhaForte@srv123.hstgr.io:5432/u123456789_copa
# Ex Neon/Supabase: postgresql://user:pass@ep-xxxx.sa-east-1.aws.neon.tech:5432/neondb?sslmode=require
DATABASE_URL=postgresql://USUARIO:SENHA@HOST_REAL:5432/NOME_DO_BANCO
JWT_SECRET=troque_por_um_secret_longo_e_aleatorio

# NewCorban API v2 (ranking, login consultores)
NEWCORBAN_USERNAME=seu.usuario
NEWCORBAN_PASSWORD=SuaSenha
NEWCORBAN_SUBDOMAIN=grupodigital

# ── Recomendadas em produção ───────────────────────────────
# Servir frontend buildado pelo mesmo processo Node (website builder)
SERVE_STATIC=true

# Origem permitida no CORS (deixe vazio se SERVE_STATIC=true — mesmo domínio)
# CORS_ORIGIN=https://seu-dominio.com.br

# Bind (padrão 0.0.0.0 — necessário em PaaS)
# HOST=0.0.0.0

# ── NewCorban API de propostas (POST /api/propostas/) ──────────
# OBRIGATÓRIA se os defaults botapi/api@bot321 não funcionarem para sua conta:
NEWCORBAN_API_USERNAME=seu.usuario.propostas
NEWCORBAN_API_PASSWORD=SuaSenhaPropostas

# ── Opcional ───────────────────────────────────────────────
# API football-data.org (calendário Copa)
# FOOTBALL_API_KEY=

# ── Docker Compose local (não usar no website builder) ─────
# DB_PASSWORD=copa_pass_2026
# VITE_API_URL=http://localhost:3001
# BACKEND_URL=http://backend:3001
