{
  "name": "copa-gd",
  "version": "1.0.0",
  "private": true,
  "description": "Copa GD 2026 — gamificação de vendas (monorepo)",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "install:backend": "npm install --prefix backend --omit=dev",
    "install:frontend": "npm install --prefix frontend --include=dev",
    "install:all": "npm run install:backend && npm run install:frontend",
    "build": "npm run install:all && npm run build --prefix frontend",
    "start": "node backend/src/server.js",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend"
  }
}
